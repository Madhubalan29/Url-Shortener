# === PostgreSQL ===
POSTGRES_DB=url_shortener
POSTGRES_USER=shortener
POSTGRES_PASSWORD=shortener_secret_123

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6379

# === Kafka ===
KAFKA_BROKER=kafka:9092

# === Shortener Service ===
SERVER_PORT=8080
BASE_URL=http://localhost

# === Rate Limiting ===
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
